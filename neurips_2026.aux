\@writefile{toc}{\contentsline {paragraph}{Experimental setup.}{10}{section*.30}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Q1: Cross-domain subspace isolation.}{10}{section*.31}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Geometry contrast between sycophancy and gender across completed layers 4, 8, and 12. This is a focused contrast between the primary nonlinear case and the diagnostic baseline, not an all-dataset geometry census. Lower intrinsic dimension and larger local-vs-global angle indicate stronger nonlinearity: a concept whose erasure direction varies significantly across the input space, making a single fixed direction insufficient to capture the full concept. Sycophancy shows substantially higher nonlinearity (dim 34--53, angle 76.9--82.6$^\circ $) compared to gender (dim 365--461, angle 51.8--55.8$^\circ $), supporting sycophancy as the primary case for manifold-aware erasure methods. This table demonstrates the geometric contrast but does not establish causality: it does not prove that the observed nonlinearity will be converted into lower displacement or higher utility preservation by any particular erasure method.}}{11}{table.caption.34}\protected@file@percent }
\newlabel{tab:geometry_contrast_summary}{{6}{11}{Geometry contrast between sycophancy and gender across completed layers 4, 8, and 12. This is a focused contrast between the primary nonlinear case and the diagnostic baseline, not an all-dataset geometry census. Lower intrinsic dimension and larger local-vs-global angle indicate stronger nonlinearity: a concept whose erasure direction varies significantly across the input space, making a single fixed direction insufficient to capture the full concept. Sycophancy shows substantially higher nonlinearity (dim 34--53, angle 76.9--82.6$^\circ $) compared to gender (dim 365--461, angle 51.8--55.8$^\circ $), supporting sycophancy as the primary case for manifold-aware erasure methods. This table demonstrates the geometric contrast but does not establish causality: it does not prove that the observed nonlinearity will be converted into lower displacement or higher utility preservation by any particular erasure method}{table.caption.34}{}}
\@writefile{toc}{\contentsline {paragraph}{Q2: Subspace sensitivity concentration.}{11}{section*.32}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Manifold curvature: why global subspaces are insufficient.}{11}{section*.33}\protected@file@percent }
\citation{karkkainen2021fairface}
\newlabel{fig:q1_transfer}{{1a}{12}{Q1: cross-domain linear subspace transfer (top-1 next-token agreement, $k \approx m_{\mathrm {tgt}}$). Each cell measures how well source-domain representations are preserved when projected onto the global PCA subspace of the target domain. High diagonal values confirm per-domain subspace self-sufficiency. Sycophancy is the structural outlier: near-zero off-diagonal transfer to biasbios ($0.002$) and code ($0.13$) indicates that sycophancy's principal subspace is nearly orthogonal to those of other tasks}{figure.caption.36}{}}
\newlabel{sub@fig:q1_transfer}{{a}{12}{Q1: cross-domain linear subspace transfer (top-1 next-token agreement, $k \approx m_{\mathrm {tgt}}$). Each cell measures how well source-domain representations are preserved when projected onto the global PCA subspace of the target domain. High diagonal values confirm per-domain subspace self-sufficiency. Sycophancy is the structural outlier: near-zero off-diagonal transfer to biasbios ($0.002$) and code ($0.13$) indicates that sycophancy's principal subspace is nearly orthogonal to those of other tasks}{figure.caption.36}{}}
\newlabel{fig:q2_sensitivity}{{1b}{12}{Q2: subspace sensitivity (off/on top-1 agreement ratio, $\epsilon = 0.5$). Values above~1 (red) indicate that on-subspace perturbations are more disruptive than equally sized off-subspace perturbations, confirming the subspace as the primary carrier of task-relevant computation. Sycophancy diagonal ($1.16$, darkest red) shows the strongest sensitivity asymmetry. Blue off-diagonal entries in the sycophancy column ($0.79$, $0.72$) confirm that the sycophancy subspace is a null direction for biasbios and code predictions}{figure.caption.36}{}}
\newlabel{sub@fig:q2_sensitivity}{{b}{12}{Q2: subspace sensitivity (off/on top-1 agreement ratio, $\epsilon = 0.5$). Values above~1 (red) indicate that on-subspace perturbations are more disruptive than equally sized off-subspace perturbations, confirming the subspace as the primary carrier of task-relevant computation. Sycophancy diagonal ($1.16$, darkest red) shows the strongest sensitivity asymmetry. Blue off-diagonal entries in the sycophancy column ($0.79$, $0.72$) confirm that the sycophancy subspace is a null direction for biasbios and code predictions}{figure.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Geometric diagnostics at layer~8 of Qwen2.5-0.5B across five domains (biasbios, code, math, safety, sycophancy). Rows index the source domain whose representations are used; columns index the domain whose global PCA subspace is applied. \textbf  {Left (Q1):} linear subspace transfer matrix. \textbf  {Right (Q2):} subspace sensitivity ratio. Both experiments use 500 evaluation samples per domain with 2{,}000 additional held-out samples for intrinsic-dimension estimation.}}{12}{figure.caption.36}\protected@file@percent }
\newlabel{fig:geom_combined}{{1}{12}{Geometric diagnostics at layer~8 of Qwen2.5-0.5B across five domains (biasbios, code, math, safety, sycophancy). Rows index the source domain whose representations are used; columns index the domain whose global PCA subspace is applied. \textbf {Left (Q1):} linear subspace transfer matrix. \textbf {Right (Q2):} subspace sensitivity ratio. Both experiments use 500 evaluation samples per domain with 2{,}000 additional held-out samples for intrinsic-dimension estimation}{figure.caption.36}{}}
