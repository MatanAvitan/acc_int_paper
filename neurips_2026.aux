\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Gender (Bias in Bios): per-model nonlinear-probe accuracy at four control-damage budgets.} Each row is one budget. Each model group has three bars (gray = clean, blue = TanGCE{} at $\varepsilon {=}0.1$, red = Obliviator paper-HP) plus a black tick at the per-model majority-class floor. Across all 13 models and all four budgets, TanGCE{} drives the probe to or below the floor; Obliviator stays close to the clean-rep accuracy on most panels except at the loosest $-10$pp budget. Sycophancy and safety analogues are in App.~Fig.~\ref {fig:per_model_bars_sycophancy_app}--\ref {fig:per_model_bars_safety_app}.}}{8}{figure.caption.15}\protected@file@percent }
\newlabel{fig:per_model_bars_gender}{{1}{8}{\textbf {Gender (Bias in Bios): per-model nonlinear-probe accuracy at four control-damage budgets.} Each row is one budget. Each model group has three bars (gray = clean, blue = \TanGCE {} at $\varepsilon {=}0.1$, red = Obliviator paper-HP) plus a black tick at the per-model majority-class floor. Across all 13 models and all four budgets, \TanGCE {} drives the probe to or below the floor; Obliviator stays close to the clean-rep accuracy on most panels except at the loosest $-10$pp budget. Sycophancy and safety analogues are in App.~Fig.~\ref {fig:per_model_bars_sycophancy_app}--\ref {fig:per_model_bars_safety_app}}{figure.caption.15}{}}
