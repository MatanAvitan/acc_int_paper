\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Main result.} \emph  {Leakage (pp)}: signed $S - S_{\text  {floor}}$ at the trajectory step closest to majority-class chance, in pp; $0$ = at chance, lower in absolute value = stronger erasure. \emph  {@chance}: settings driven to chance ($|S{-}S_{\text  {floor}}| \le 0.5$pp) over settings the method reached the budget on. All 39 NLP panels (13 model families $\times $ 3 concepts) at 50\%-depth, fresh nonlinear probe ($h{=}128$, 200 SGD, patience 3); LEACE-only and LEACE$+$CovMatch $K{=}2$ are one-shot closed-form. TanGCE\textsuperscript  {++}{} is the proposed pipeline at fixed $\varepsilon {=}0.1$, $h{=}512$; TanGCE{} drops both preprocessing stages and TanGCE\textsuperscript  {+}{} drops only CovMatch. Bold = column-best; multiple methods within 0.05pp of the best are all bolded. Per-panel detail across all 39 panels is in App.~Tab.~\ref {tab:per_panel_breakdown}.}}{10}{table.caption.22}\protected@file@percent }
\newlabel{tab:main_results_unified}{{1}{10}{\textbf {Main result.} \emph {Leakage (pp)}: signed $S - S_{\text {floor}}$ at the trajectory step closest to majority-class chance, in pp; $0$ = at chance, lower in absolute value = stronger erasure. \emph {@chance}: settings driven to chance ($|S{-}S_{\text {floor}}| \le 0.5$pp) over settings the method reached the budget on. All 39 NLP panels (13 model families $\times $ 3 concepts) at 50\%-depth, fresh nonlinear probe ($h{=}128$, 200 SGD, patience 3); LEACE-only and LEACE$+$CovMatch $K{=}2$ are one-shot closed-form. \TanGCEpp {} is the proposed pipeline at fixed $\varepsilon {=}0.1$, $h{=}512$; \TanGCE {} drops both preprocessing stages and \TanGCEp {} drops only CovMatch. Bold = column-best; multiple methods within 0.05pp of the best are all bolded. Per-panel detail across all 39 panels is in App.~Tab.~\ref {tab:per_panel_breakdown}}{table.caption.22}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.2}TanGCE complements every Phase-1 baseline}{10}{subsection.7.2}\protected@file@percent }
\newlabel{sec:tangce_on_baseline}{{7.2}{10}{TanGCE complements every Phase-1 baseline}{subsection.7.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.3}Per-model bars and the surgicality signal}{10}{subsection.7.3}\protected@file@percent }
\newlabel{sec:pareto_obliviator}{{7.3}{10}{Per-model bars and the surgicality signal}{subsection.7.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Aggregated NLP leakage vs.\ control-damage budget.} Mean $|S - S_{\text  {floor}}|$ in pp across the 39 NLP settings (13 model families $\times $ 3 concepts at 50\%-depth) for each method, plotted against the four control-damage budgets $\Delta Y \in \{1, 3, 5, 10\}$pp. The black ``X'' at $x=0$ is the shared starting point: mean nonlinear-probe leakage on the raw, un-erased representations ($\sim $24pp); every line begins from this anchor. Lower is better; the $y$-axis floor is the per-setting majority-class chance. The TanGCE{} family (TanGCE\textsuperscript  {++}{}, TanGCE\textsuperscript  {+}{}, TanGCE{}) traces the lowest envelope at every budget --- TanGCE\textsuperscript  {++}{} below $1$pp from $\le 3$pp onward --- while baselines (Obliviator, LEACE\,+\,CovMatch K=2, IGBP, AmbGCE, INLP, LEACE) plateau at $4$--$18$pp regardless of how much utility one is willing to sacrifice. The visual gap between the TanGCE{} curves and the rest reproduces the column-best ranking in Tab.~\ref {tab:main_results_unified}.}}{11}{figure.caption.23}\protected@file@percent }
\newlabel{fig:aggregated_nlp_results}{{2}{11}{\textbf {Aggregated NLP leakage vs.\ control-damage budget.} Mean $|S - S_{\text {floor}}|$ in pp across the 39 NLP settings (13 model families $\times $ 3 concepts at 50\%-depth) for each method, plotted against the four control-damage budgets $\Delta Y \in \{1, 3, 5, 10\}$pp. The black ``X'' at $x=0$ is the shared starting point: mean nonlinear-probe leakage on the raw, un-erased representations ($\sim $24pp); every line begins from this anchor. Lower is better; the $y$-axis floor is the per-setting majority-class chance. The \TanGCE {} family (\TanGCEpp {}, \TanGCEp {}, \TanGCE {}) traces the lowest envelope at every budget --- \TanGCEpp {} below $1$pp from $\le 3$pp onward --- while baselines (Obliviator, LEACE\,+\,CovMatch K=2, IGBP, AmbGCE, INLP, LEACE) plateau at $4$--$18$pp regardless of how much utility one is willing to sacrifice. The visual gap between the \TanGCE {} curves and the rest reproduces the column-best ranking in Tab.~\ref {tab:main_results_unified}}{figure.caption.23}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.4}Cross-modal generalization: CelebA dual control regimes}{11}{subsection.7.4}\protected@file@percent }
\newlabel{sec:celeba}{{7.4}{11}{Cross-modal generalization: CelebA dual control regimes}{subsection.7.4}{}}
\@writefile{toc}{\contentsline {paragraph}{Setup.}{11}{section*.26}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {TanGCE complements every Phase-1 baseline.} Mean $|S{-}S_{\text  {floor}}|$ in pp at the trajectory step closest to chance, with $\Delta Y$ measured against the original clean reps (same budget convention as Tab.~\ref {tab:main_results_unified}). For each baseline B, the ``alone'' column reports B's endpoint leakage on settings where B kept $Y$ within the budget; the ``Improvement'' column is the mean reduction in leakage after stacking TanGCE on B's reps (positive $=$ TanGCE moved closer to chance), evaluated on the same settings. For the reference rows (TanGCE{} on raw reps and the SOTA pipeline LEACE\,+\,CovMatch $\to $ TanGCE{}) there is no Phase-1-alone baseline; the Improvement slot italicises the absolute post-TanGCE leakage instead. Reach $\!=\!$ (settings in budget)$/$(settings with data). The TanGCE{}-only and LEACE\,+\,CovMatch $\to $ TanGCE{} rows are reference rows for context (TanGCE on clean reps; full SOTA pipeline). $^\dagger ${}\textbf  {Obliviator surgicality warning:} Obliviator overshoots the $\Delta Y$ budget on \emph  {every} sycophancy and gender setting ($26/26$); the only settings on which it lands in budget are the $13$ safety settings, where the safety task accuracy floor happens to coincide with Obliviator's encoder-collapse Y. The $0.0$pp leakage on those $13$ settings reflects this collapse, not a genuine surgical erasure --- it is an artefact of Obliviator destroying control accuracy until $Y$ matches the panel's $Y_{\text  {floor}}$.}}{12}{table.caption.24}\protected@file@percent }
\newlabel{tab:tangce_on_baseline}{{2}{12}{\textbf {TanGCE complements every Phase-1 baseline.} Mean $|S{-}S_{\text {floor}}|$ in pp at the trajectory step closest to chance, with $\Delta Y$ measured against the original clean reps (same budget convention as Tab.~\ref {tab:main_results_unified}). For each baseline B, the ``alone'' column reports B's endpoint leakage on settings where B kept $Y$ within the budget; the ``Improvement'' column is the mean reduction in leakage after stacking TanGCE on B's reps (positive $=$ TanGCE moved closer to chance), evaluated on the same settings. For the reference rows (\TanGCE {} on raw reps and the SOTA pipeline LEACE\,+\,CovMatch $\to $ \TanGCE {}) there is no Phase-1-alone baseline; the Improvement slot italicises the absolute post-TanGCE leakage instead. Reach $\!=\!$ (settings in budget)$/$(settings with data). The \TanGCE {}-only and LEACE\,+\,CovMatch $\to $ \TanGCE {} rows are reference rows for context (TanGCE on clean reps; full SOTA pipeline). $^\dagger ${}\textbf {Obliviator surgicality warning:} Obliviator overshoots the $\Delta Y$ budget on \emph {every} sycophancy and gender setting ($26/26$); the only settings on which it lands in budget are the $13$ safety settings, where the safety task accuracy floor happens to coincide with Obliviator's encoder-collapse Y. The $0.0$pp leakage on those $13$ settings reflects this collapse, not a genuine surgical erasure --- it is an artefact of Obliviator destroying control accuracy until $Y$ matches the panel's $Y_{\text {floor}}$}{table.caption.24}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {CelebA cross-modal results (CLIP ViT-B/32, 40 binary attributes).} \emph  {Leakage (pp)}: signed $S - S_{\text  {floor}}$ at the trajectory step closest to the per-attribute majority-class chance; $0$ = at chance, lower in absolute value = stronger erasure. \emph  {@chance}: settings driven to chance ($|S{-}S_{\text  {floor}}| \le 0.5$pp) over settings the method reached the budget on. Each method is run on 40 attributes under each control regime (5 least- vs.\ 5 most-correlated controls per target). The CelebA pipeline uses the same TanGCE\textsuperscript  {++}{} recipe as the NLP headline: LEACE preprocessing $+$ rank-2 CovMatch $K{=}2$ $+$ manifold loop. Best per column in \textbf  {bold}. `--' = no in-budget step at that budget for that method.}}{12}{table.caption.27}\protected@file@percent }
\newlabel{tab:celeba_unified_summary}{{3}{12}{\textbf {CelebA cross-modal results (CLIP ViT-B/32, 40 binary attributes).} \emph {Leakage (pp)}: signed $S - S_{\text {floor}}$ at the trajectory step closest to the per-attribute majority-class chance; $0$ = at chance, lower in absolute value = stronger erasure. \emph {@chance}: settings driven to chance ($|S{-}S_{\text {floor}}| \le 0.5$pp) over settings the method reached the budget on. Each method is run on 40 attributes under each control regime (5 least- vs.\ 5 most-correlated controls per target). The CelebA pipeline uses the same \TanGCEpp {} recipe as the NLP headline: LEACE preprocessing $+$ rank-2 CovMatch $K{=}2$ $+$ manifold loop. Best per column in \textbf {bold}. `--' = no in-budget step at that budget for that method}{table.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Gender (Bias in Bios): per-model nonlinear-probe accuracy at the tightest and a moderate control-damage budget.} Two budgets are shown ($\Delta Y \le 1$pp and $\le 5$pp); each model group has three bars (gray = clean, blue = TanGCE\textsuperscript  {++}{}, red = Obliviator) plus a black tick at the per-model majority-class floor. Across all 13 models and both budgets, TanGCE\textsuperscript  {++}{} drives the probe to or below the floor; Obliviator stays close to the clean-rep accuracy on most settings. The full four-budget version of this figure is in App.~Fig.~\ref {fig:per_model_bars_gender_full}; sycophancy and safety analogues are in App.~Fig.~\ref {fig:per_model_bars_sycophancy_app}--\ref {fig:per_model_bars_safety_app}.}}{13}{figure.caption.25}\protected@file@percent }
\newlabel{fig:per_model_bars_gender}{{3}{13}{\textbf {Gender (Bias in Bios): per-model nonlinear-probe accuracy at the tightest and a moderate control-damage budget.} Two budgets are shown ($\Delta Y \le 1$pp and $\le 5$pp); each model group has three bars (gray = clean, blue = \TanGCEpp {}, red = Obliviator) plus a black tick at the per-model majority-class floor. Across all 13 models and both budgets, \TanGCEpp {} drives the probe to or below the floor; Obliviator stays close to the clean-rep accuracy on most settings. The full four-budget version of this figure is in App.~Fig.~\ref {fig:per_model_bars_gender_full}; sycophancy and safety analogues are in App.~Fig.~\ref {fig:per_model_bars_sycophancy_app}--\ref {fig:per_model_bars_safety_app}}{figure.caption.25}{}}
