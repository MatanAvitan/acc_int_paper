\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Gender (Bias in Bios): per-model nonlinear-probe accuracy at four control-damage budgets.} Each row is one budget; each model group has three bars — gray = clean, blue = TanGCE{} ($\varepsilon {=}0.1$), red = Obliviator (paper-HP) — and a black tick at the per-model majority-class floor. Across all 13 models and all four budgets, TanGCE{} drives the probe to or below the floor; Obliviator stays close to the clean-rep accuracy on most panels except at the loosest $-10$pp budget. Sycophancy and safety analogues are in App.~Fig.~\ref {fig:per_model_bars_sycophancy_app}--\ref {fig:per_model_bars_safety_app}.}}{8}{figure.caption.15}\protected@file@percent }
\newlabel{fig:per_model_bars_gender}{{1}{8}{\textbf {Gender (Bias in Bios): per-model nonlinear-probe accuracy at four control-damage budgets.} Each row is one budget; each model group has three bars — gray = clean, blue = \TanGCE {} ($\varepsilon {=}0.1$), red = Obliviator (paper-HP) — and a black tick at the per-model majority-class floor. Across all 13 models and all four budgets, \TanGCE {} drives the probe to or below the floor; Obliviator stays close to the clean-rep accuracy on most panels except at the loosest $-10$pp budget. Sycophancy and safety analogues are in App.~Fig.~\ref {fig:per_model_bars_sycophancy_app}--\ref {fig:per_model_bars_safety_app}}{figure.caption.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {CelebA cross-modal results (CLIP ViT-B/32, 40 binary attributes).} Best-in-budget distance to the per-attribute majority-class chance: signed $S - S_{\text  {floor}}$ at the trajectory step closest to floor (in pp), and panels at floor ($|S-S_{\text  {floor}}| \le 0.5$pp) over panels reaching the budget. Each method is run on 40 attributes under each control regime (5 least- vs.\ 5 most-correlated controls per target). $\lambda $-based methods use $\lambda \approx 30$, matching the NLP setup. Best per column in \textbf  {bold}. `--' = no in-budget step at that budget for that method.}}{9}{table.caption.17}\protected@file@percent }
\newlabel{tab:celeba_unified_summary}{{2}{9}{\textbf {CelebA cross-modal results (CLIP ViT-B/32, 40 binary attributes).} Best-in-budget distance to the per-attribute majority-class chance: signed $S - S_{\text {floor}}$ at the trajectory step closest to floor (in pp), and panels at floor ($|S-S_{\text {floor}}| \le 0.5$pp) over panels reaching the budget. Each method is run on 40 attributes under each control regime (5 least- vs.\ 5 most-correlated controls per target). $\lambda $-based methods use $\lambda \approx 30$, matching the NLP setup. Best per column in \textbf {bold}. `--' = no in-budget step at that budget for that method}{table.caption.17}{}}
