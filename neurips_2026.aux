\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Full erasure method comparison at layer~8 across three concept domains (Qwen2.5-0.5B), plus a Majority Class reference floor. Each $\lambda $-based method's $\lambda ^*$ is selected from $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation nonlinear probe accuracy; the same probe architecture (MLP hidden 256, 1500 steps, AdamW lr=$10^{-3}$) is used for both HPO and final evaluation, ensuring no ranking distortion from mismatched capacity. IGBP and linear baselines use their standard procedure. Majority Class is not an erasure method; it reports the label-imbalance floor implied by the test split. L/NL Leak: retrained linear logistic-regression / nonlinear MLP probe accuracy on the target concept (lower = stronger erasure). $\Delta $Ctrl: downstream control-task accuracy change relative to clean representations (closer to zero = more surgical). Control tasks: answer matching (sycophancy), profession classification (gender), helpfulness (safety).}}{13}{table.caption.25}\protected@file@percent }
\newlabel{tab:full_comparison}{{3}{13}{Full erasure method comparison at layer~8 across three concept domains (Qwen2.5-0.5B), plus a Majority Class reference floor. Each $\lambda $-based method's $\lambda ^*$ is selected from $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation nonlinear probe accuracy; the same probe architecture (MLP hidden 256, 1500 steps, AdamW lr=$10^{-3}$) is used for both HPO and final evaluation, ensuring no ranking distortion from mismatched capacity. IGBP and linear baselines use their standard procedure. Majority Class is not an erasure method; it reports the label-imbalance floor implied by the test split. L/NL Leak: retrained linear logistic-regression / nonlinear MLP probe accuracy on the target concept (lower = stronger erasure). $\Delta $Ctrl: downstream control-task accuracy change relative to clean representations (closer to zero = more surgical). Control tasks: answer matching (sycophancy), profession classification (gender), helpfulness (safety)}{table.caption.25}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces All erasure methods on all models --- \textbf  {Sycophancy} concept. NL: retrained nonlinear MLP probe accuracy (lower = stronger erasure). $\Delta $Ctrl: downstream control-task accuracy change (closer to zero = more surgical). Values are mean\,$\pm $\,std across 25\%/50\%/75\% depth layers. \textbf  {Bold} marks the lowest NL per model among non-random methods.}}{13}{table.4}\protected@file@percent }
\newlabel{tab:appendix_all_methods_sycophancy}{{4}{13}{All erasure methods on all models --- \textbf {Sycophancy} concept. NL: retrained nonlinear MLP probe accuracy (lower = stronger erasure). $\Delta $Ctrl: downstream control-task accuracy change (closer to zero = more surgical). Values are mean\,$\pm $\,std across 25\%/50\%/75\% depth layers. \textbf {Bold} marks the lowest NL per model among non-random methods}{table.4}{}}
