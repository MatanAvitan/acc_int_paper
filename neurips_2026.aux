\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Full erasure method comparison at layer 8 across three concept domains. Each $\lambda $-based method's $\lambda ^*$ is selected from the same grid $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation nonlinear probe accuracy, ensuring a fair comparison where every method gets its best shot at erasure; non-$\lambda $ baselines use their standard procedure. L/NL Leak: retrained linear logistic-regression / nonlinear MLP probe accuracy on the target concept (lower = stronger erasure precision). $\Delta $Ctrl: downstream control-task accuracy change relative to clean representations (closer to zero = more surgical). Model: Qwen2.5-0.5B. Control tasks: answer matching (sycophancy), profession classification (gender), helpfulness (safety).}}{8}{table.caption.25}\protected@file@percent }
\newlabel{tab:full_comparison}{{2}{8}{Full erasure method comparison at layer 8 across three concept domains. Each $\lambda $-based method's $\lambda ^*$ is selected from the same grid $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation nonlinear probe accuracy, ensuring a fair comparison where every method gets its best shot at erasure; non-$\lambda $ baselines use their standard procedure. L/NL Leak: retrained linear logistic-regression / nonlinear MLP probe accuracy on the target concept (lower = stronger erasure precision). $\Delta $Ctrl: downstream control-task accuracy change relative to clean representations (closer to zero = more surgical). Model: Qwen2.5-0.5B. Control tasks: answer matching (sycophancy), profession classification (gender), helpfulness (safety)}{table.caption.25}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces $\lambda $ sweep comparing AmbGCE{} and TanGCE{} at matched step sizes across three concept domains (Qwen2.5-0.5B, layer~8). NL: retrained nonlinear probe accuracy on the target concept (lower = stronger erasure). AmbGCE{} deteriorates at high $\lambda $ (rising leakage), while TanGCE{} continues improving, supporting the claim that on-manifold updates can safely employ larger erasure strengths. Bold: best NL per domain.}}{8}{table.caption.26}\protected@file@percent }
\newlabel{tab:lambda_sweep}{{3}{8}{$\lambda $ sweep comparing \AmbGCE {} and \TanGCE {} at matched step sizes across three concept domains (Qwen2.5-0.5B, layer~8). NL: retrained nonlinear probe accuracy on the target concept (lower = stronger erasure). \AmbGCE {} deteriorates at high $\lambda $ (rising leakage), while \TanGCE {} continues improving, supporting the claim that on-manifold updates can safely employ larger erasure strengths. Bold: best NL per domain}{table.caption.26}{}}
