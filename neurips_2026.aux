\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces \textbf  {Phase-1 closed-form ablations on the 39-panel NLP grid (50\%-depth layer).} Same fresh nonlinear probe ($h=128$, 200 SGD steps, patience 3) is trained on each post-erasure representation. \emph  {LEACE} is the affine LEACE eraser. \emph  {LEACE\,+\,CovMatch K=2} additionally projects out the top-2 eigenvectors of $\Delta \Sigma = \Sigma _{+} - \Sigma _{-}$ (rank-3 closed-form erasure total). \emph  {TanGCE} is the proposed full pipeline (Phase 1 + iterative tangent loop, $\varepsilon {=}0.1$); we report the best $|S{-}\text  {floor}|$ trajectory step subject to $\Delta Y \geq -5$pp. NL = nonlinear probe accuracy on test (lower is better; floor is the per-panel majority class). $\Delta Y$ in pp on the control task. Bold marks the row's NL minimum.}}{19}{table.caption.25}\protected@file@percent }
\newlabel{tab:leace_vs_tangce_nlp}{{3}{19}{\textbf {Phase-1 closed-form ablations on the 39-panel NLP grid (50\%-depth layer).} Same fresh nonlinear probe ($h=128$, 200 SGD steps, patience 3) is trained on each post-erasure representation. \emph {LEACE} is the affine LEACE eraser. \emph {LEACE\,+\,CovMatch K=2} additionally projects out the top-2 eigenvectors of $\Delta \Sigma = \Sigma _{+} - \Sigma _{-}$ (rank-3 closed-form erasure total). \emph {TanGCE} is the proposed full pipeline (Phase 1 + iterative tangent loop, $\varepsilon {=}0.1$); we report the best $|S{-}\text {floor}|$ trajectory step subject to $\Delta Y \geq -5$pp. NL = nonlinear probe accuracy on test (lower is better; floor is the per-panel majority class). $\Delta Y$ in pp on the control task. Bold marks the row's NL minimum}{table.caption.25}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces \textbf  {Per-panel breakdown.} Signed $(S-S_{\text  {floor}})$ in pp at the trajectory step closest to the per-panel majority-class floor, subject to $|\Delta Y| \le B$pp control-damage budget. Bold = best (smallest absolute deviation from floor) per panel per budget block. `--' = no in-budget step at that budget for that method. Final rows: per-budget per-method mean across the 39 panels and TanGCE{} W/T/L counts vs.\ the best other method (0.5pp tie band).}}{20}{table.caption.28}\protected@file@percent }
\newlabel{tab:per_panel_breakdown}{{4}{20}{\textbf {Per-panel breakdown.} Signed $(S-S_{\text {floor}})$ in pp at the trajectory step closest to the per-panel majority-class floor, subject to $|\Delta Y| \le B$pp control-damage budget. Bold = best (smallest absolute deviation from floor) per panel per budget block. `--' = no in-budget step at that budget for that method. Final rows: per-budget per-method mean across the 39 panels and \TanGCE {} W/T/L counts vs.\ the best other method (0.5pp tie band)}{table.caption.28}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \textbf  {CelebA per-attribute breakdown (40 attributes $\times $ 2 control regimes).} Signed $(S-S_{\text  {floor}})$ in pp at the trajectory step closest to the per-attribute majority-class floor, subject to mean $\Delta Y \ge -5$pp on the 5 controls. Bold = best (smallest absolute deviation from floor) per attribute per regime block. `--' = no in-budget step at that budget for that method. Final rows: per-regime per-method mean and TanGCE{} W/T/L counts vs.\ the best other method (0.5pp tie band).}}{21}{table.caption.29}\protected@file@percent }
\newlabel{tab:celeba_per_panel_breakdown}{{5}{21}{\textbf {CelebA per-attribute breakdown (40 attributes $\times $ 2 control regimes).} Signed $(S-S_{\text {floor}})$ in pp at the trajectory step closest to the per-attribute majority-class floor, subject to mean $\Delta Y \ge -5$pp on the 5 controls. Bold = best (smallest absolute deviation from floor) per attribute per regime block. `--' = no in-budget step at that budget for that method. Final rows: per-regime per-method mean and \TanGCE {} W/T/L counts vs.\ the best other method (0.5pp tie band)}{table.caption.29}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces \textbf  {Per-row $\lambda _i$ statistics for the proposed pipeline ($\varepsilon = 0.1$, $\lambda _{\max }=64$) on the 39-panel NLP grid at 50\%-depth.} Each cell averages the per-row $\lambda _i$ first across all 60 outer iterations of one trajectory, then across the 13 model panels of the concept. The within-panel $p_{10}/p_{90}$ spread (mean across panels) is roughly $14/45$, i.e.\ a $\sim $10$\times $ ratio between the least- and most-confident rows in a single iteration. The safety cap $\lambda _{\max }=64$ is observed only sporadically (max 57.32 across 39$\times $60 = 2340 iterations); the closed-form rule rarely binds against it.}}{21}{table.caption.39}\protected@file@percent }
\newlabel{tab:lambda_stats}{{6}{21}{\textbf {Per-row $\lambda _i$ statistics for the proposed pipeline ($\varepsilon = 0.1$, $\lambda _{\max }=64$) on the 39-panel NLP grid at 50\%-depth.} Each cell averages the per-row $\lambda _i$ first across all 60 outer iterations of one trajectory, then across the 13 model panels of the concept. The within-panel $p_{10}/p_{90}$ spread (mean across panels) is roughly $14/45$, i.e.\ a $\sim $10$\times $ ratio between the least- and most-confident rows in a single iteration. The safety cap $\lambda _{\max }=64$ is observed only sporadically (max 57.32 across 39$\times $60 = 2340 iterations); the closed-form rule rarely binds against it}{table.caption.39}{}}
