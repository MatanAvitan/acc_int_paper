\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Pareto comparison vs.\ Obliviator under control-damage budgets}{16}{subsection.6.2}\protected@file@percent }
\newlabel{sec:pareto_obliviator}{{6.2}{16}{Pareto comparison vs.\ Obliviator under control-damage budgets}{subsection.6.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Floor-distance win-margin (TanGCE{} $-$ Obliviator) per panel under control-damage budgets $\Delta Y \in \{1, 3, 5, 10\}$ pp at 50\%-depth. Each row is one (model, concept) panel; positive (blue) values mean TanGCE{} is closer to the majority-class floor than Obliviator at that budget. The full pipeline (LEACE + rank-2 covariance projection + $h{=}512$ scorer + $\varepsilon {=}0.1$) is closer to floor on every budget and never loses by more than the $\pm 5$pp tie band: $0$ losses, $6$--$9$ strict wins ($>5$pp), $30$--$33$ ties out of $38$--$39$ panels. Mean improvement over Obliviator: $+2.4$pp at $\Delta Y \geq -1$pp, $+3.4$pp at $-3$pp, $+3.8$pp at $-5$pp, $+3.0$pp at $-10$pp. Reach-floor (within $\pm 0.5$pp): $21$--$32/39$ panels (TanGCE{}) vs.\ $13$--$17/39$ (Obliviator).}}{17}{figure.caption.47}\protected@file@percent }
\newlabel{fig:pareto_sota_obliv_floor}{{1}{17}{Floor-distance win-margin (\TanGCE {} $-$ Obliviator) per panel under control-damage budgets $\Delta Y \in \{1, 3, 5, 10\}$ pp at 50\%-depth. Each row is one (model, concept) panel; positive (blue) values mean \TanGCE {} is closer to the majority-class floor than Obliviator at that budget. The full pipeline (LEACE + rank-2 covariance projection + $h{=}512$ scorer + $\varepsilon {=}0.1$) is closer to floor on every budget and never loses by more than the $\pm 5$pp tie band: $0$ losses, $6$--$9$ strict wins ($>5$pp), $30$--$33$ ties out of $38$--$39$ panels. Mean improvement over Obliviator: $+2.4$pp at $\Delta Y \geq -1$pp, $+3.4$pp at $-3$pp, $+3.8$pp at $-5$pp, $+3.0$pp at $-10$pp. Reach-floor (within $\pm 0.5$pp): $21$--$32/39$ panels (\TanGCE {}) vs.\ $13$--$17/39$ (Obliviator)}{figure.caption.47}{}}
\newlabel{par:phase1_only}{{6.2}{17}{What does Phase 1 alone get us? (closed-form ablation)}{section*.52}{}}
\@writefile{toc}{\contentsline {paragraph}{What does Phase 1 alone get us? (closed-form ablation).}{17}{section*.52}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Sycophancy: per-model nonlinear-probe accuracy at four control-damage budgets.} Each row is one $\Delta Y$ budget. Within each row, the 13 model panels are shown as groups; each group has three bars — gray = clean (no erasure), blue = TanGCE{} at $\varepsilon {=}0.1$, red = Obliviator paper-HP. The thick horizontal black tick on each group is that model's per-panel majority-class floor (the trivial probe ceiling); a bar reaching that mark indicates full erasure under the budget. ``n/a'' means the method had no trajectory step satisfying the $\Delta Y$ constraint on that panel. Lower bars are better.}}{18}{figure.caption.48}\protected@file@percent }
\newlabel{fig:per_model_bars_sycophancy}{{2}{18}{\textbf {Sycophancy: per-model nonlinear-probe accuracy at four control-damage budgets.} Each row is one $\Delta Y$ budget. Within each row, the 13 model panels are shown as groups; each group has three bars — gray = clean (no erasure), blue = \TanGCE {} at $\varepsilon {=}0.1$, red = Obliviator paper-HP. The thick horizontal black tick on each group is that model's per-panel majority-class floor (the trivial probe ceiling); a bar reaching that mark indicates full erasure under the budget. ``n/a'' means the method had no trajectory step satisfying the $\Delta Y$ constraint on that panel. Lower bars are better}{figure.caption.48}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Gender (Bias in Bios): per-model nonlinear-probe accuracy at four control-damage budgets.} Same layout as Figure~\ref {fig:per_model_bars_sycophancy}. Across all 13 model panels and all four budgets, TanGCE{} drives the probe to or below the per-model majority-class floor; Obliviator stays close to the clean-rep accuracy on most panels except at the loosest $-10$pp budget.}}{19}{figure.caption.49}\protected@file@percent }
\newlabel{fig:per_model_bars_gender}{{3}{19}{\textbf {Gender (Bias in Bios): per-model nonlinear-probe accuracy at four control-damage budgets.} Same layout as Figure~\ref {fig:per_model_bars_sycophancy}. Across all 13 model panels and all four budgets, \TanGCE {} drives the probe to or below the per-model majority-class floor; Obliviator stays close to the clean-rep accuracy on most panels except at the loosest $-10$pp budget}{figure.caption.49}{}}
