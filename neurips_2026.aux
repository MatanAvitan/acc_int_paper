\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}TanGCE{} Achieves the Best Erasure Precision Across All Domains}{8}{subsection.6.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Full erasure method comparison at layer~8 across three concept domains (Qwen2.5-0.5B). Each $\lambda $-based method's $\lambda ^*$ is selected from $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation nonlinear probe accuracy; the same probe architecture (MLP hidden 256, 1500 steps, AdamW lr=$10^{-3}$) is used for both HPO and final evaluation, ensuring no ranking distortion from mismatched capacity. IGBP and linear baselines use their standard procedure. L/NL Leak: retrained linear logistic-regression / nonlinear MLP probe accuracy on the target concept (lower = stronger erasure). $\Delta $Ctrl: downstream control-task accuracy change relative to clean representations (closer to zero = more surgical). Control tasks: answer matching (sycophancy), profession classification (gender), helpfulness (safety).}}{9}{table.caption.28}\protected@file@percent }
\newlabel{tab:full_comparison}{{2}{9}{Full erasure method comparison at layer~8 across three concept domains (Qwen2.5-0.5B). Each $\lambda $-based method's $\lambda ^*$ is selected from $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation nonlinear probe accuracy; the same probe architecture (MLP hidden 256, 1500 steps, AdamW lr=$10^{-3}$) is used for both HPO and final evaluation, ensuring no ranking distortion from mismatched capacity. IGBP and linear baselines use their standard procedure. L/NL Leak: retrained linear logistic-regression / nonlinear MLP probe accuracy on the target concept (lower = stronger erasure). $\Delta $Ctrl: downstream control-task accuracy change relative to clean representations (closer to zero = more surgical). Control tasks: answer matching (sycophancy), profession classification (gender), helpfulness (safety)}{table.caption.28}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces $\lambda $ sweep comparing AmbGCE{} and TanGCE{} at fixed step sizes across three concept domains (Qwen2.5-0.5B, layer~8). NL: retrained nonlinear MLP probe accuracy (hidden 256, 1500 steps, AdamW lr=$10^{-3}$; same architecture used for HPO and evaluation) on the target concept (lower = stronger erasure). Both methods use the same GCE concept scorer (hidden 256, 1500 steps). AmbGCE{} becomes less effective at high $\lambda $ under the current protocol, while TanGCE{} continues improving. We interpret this as supportive evidence for the local manifold motivation of tangent-constrained updates, not as a complete characterization of the leakage-utility frontier. The expanded HPO grid $\{0.25,\ldots  ,32.0\}$ used in the multi-model experiments further tests this range. Bold: best NL per domain.}}{9}{table.caption.29}\protected@file@percent }
\newlabel{tab:lambda_sweep}{{3}{9}{$\lambda $ sweep comparing \AmbGCE {} and \TanGCE {} at fixed step sizes across three concept domains (Qwen2.5-0.5B, layer~8). NL: retrained nonlinear MLP probe accuracy (hidden 256, 1500 steps, AdamW lr=$10^{-3}$; same architecture used for HPO and evaluation) on the target concept (lower = stronger erasure). Both methods use the same GCE concept scorer (hidden 256, 1500 steps). \AmbGCE {} becomes less effective at high $\lambda $ under the current protocol, while \TanGCE {} continues improving. We interpret this as supportive evidence for the local manifold motivation of tangent-constrained updates, not as a complete characterization of the leakage-utility frontier. The expanded HPO grid $\{0.25,\ldots ,32.0\}$ used in the multi-model experiments further tests this range. Bold: best NL per domain}{table.caption.29}{}}
