\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces \textbf  {Per-row $\lambda _i$ statistics for the proposed method ($\varepsilon = 0.1$, $\lambda _{\max }=64$) on the 39-setting NLP grid at 50\%-depth.} Each cell averages the per-row $\lambda _i$ first across all 60 outer iterations of one trajectory, then across the 13 model settings of the concept. The within-setting $p_{10}/p_{90}$ spread (mean across settings) is roughly $14/45$, i.e.\ a $\sim $10$\times $ ratio between the least- and most-confident rows in a single iteration. The safety cap $\lambda _{\max }=64$ is observed only sporadically (max 57.32 across 39$\times $60 = 2340 iterations); the closed-form rule rarely binds against it.}}{26}{table.caption.50}\protected@file@percent }
\newlabel{tab:lambda_stats}{{7}{26}{\textbf {Per-row $\lambda _i$ statistics for the proposed method ($\varepsilon = 0.1$, $\lambda _{\max }=64$) on the 39-setting NLP grid at 50\%-depth.} Each cell averages the per-row $\lambda _i$ first across all 60 outer iterations of one trajectory, then across the 13 model settings of the concept. The within-setting $p_{10}/p_{90}$ spread (mean across settings) is roughly $14/45$, i.e.\ a $\sim $10$\times $ ratio between the least- and most-confident rows in a single iteration. The safety cap $\lambda _{\max }=64$ is observed only sporadically (max 57.32 across 39$\times $60 = 2340 iterations); the closed-form rule rarely binds against it}{table.caption.50}{}}
