\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}TanGCE Achieves Lowest Leakage Across All Domains}{8}{subsection.5.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Mutual information and fidelity metrics (layer 8). MI$_c$: concept mutual information in original representation space via $k$-NN estimator (lower = better erasure). MI$_\text  {ctrl}$: control-label mutual information (higher = better preservation of task-relevant information). Clean baselines: sycophancy MI$_c{=}0.189$, MI$_\text  {ctrl}{=}1.157$; gender MI$_c{=}0.074$, MI$_\text  {ctrl}{=}0.903$; safety MI$_c{=}0.160$, MI$_\text  {ctrl}{=}0.077$. $L_2$: mean $\ell _2$ displacement from clean representations.}}{9}{table.3}\protected@file@percent }
\newlabel{tab:full_comparison_detail}{{3}{9}{Mutual information and fidelity metrics (layer 8). MI$_c$: concept mutual information in original representation space via $k$-NN estimator (lower = better erasure). MI$_\text {ctrl}$: control-label mutual information (higher = better preservation of task-relevant information). Clean baselines: sycophancy MI$_c{=}0.189$, MI$_\text {ctrl}{=}1.157$; gender MI$_c{=}0.074$, MI$_\text {ctrl}{=}0.903$; safety MI$_c{=}0.160$, MI$_\text {ctrl}{=}0.077$. $L_2$: mean $\ell _2$ displacement from clean representations}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Control Task Preservation}{9}{subsection.5.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Near-Zero Redistribution}{9}{subsection.5.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Damage threshold sensitivity.}{9}{table.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}The $\lambda $ Sweep: Off-Manifold Displacement Creates Spurious Correlations}{9}{subsection.5.4}\protected@file@percent }
\newlabel{sec:lambda_sweep}{{5.4}{9}{The $\lambda $ Sweep: Off-Manifold Displacement Creates Spurious Correlations}{subsection.5.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Effect of disruption threshold $\delta $ on concept removal and damage rates ($64\times $ SAE). At the lenient $\delta {>}2\%$ threshold, many features register as ``damaged'' from minor perturbation; at $\delta {>}20\%$, only features with substantial activation change count. TanGCE's damage drops to 1--11\% at $\delta {>}20\%$, confirming that TanGCE's collateral impact at lenient thresholds reflects superficial activation shifts rather than genuine information disruption.}}{10}{table.4}\protected@file@percent }
\newlabel{tab:damage_threshold}{{4}{10}{Effect of disruption threshold $\delta $ on concept removal and damage rates ($64\times $ SAE). At the lenient $\delta {>}2\%$ threshold, many features register as ``damaged'' from minor perturbation; at $\delta {>}20\%$, only features with substantial activation change count. TanGCE's damage drops to 1--11\% at $\delta {>}20\%$, confirming that TanGCE's collateral impact at lenient thresholds reflects superficial activation shifts rather than genuine information disruption}{table.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.5}Polysemanticity Confounds Linear Correlation Metrics}{10}{subsection.5.5}\protected@file@percent }
\newlabel{sec:polysemanticity}{{5.5}{10}{Polysemanticity Confounds Linear Correlation Metrics}{subsection.5.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces $\lambda $ sweep comparing Ambient GCE and TanGCE at matched $\lambda $ values ($\lambda \in \{0.5, 4.0, 8.0\}$) at layer 8. L/NL: retrained linear/nonlinear probe accuracy. TanGCE retains the raw tangent projection norm as a confidence weight: if the gradient is mostly off-manifold, $\|\mathbf  {P}_T(\nabla f)\| \ll 1$ and erasure is naturally attenuated. Ambient GCE at high $\lambda $ increases MI$_c$ (negative MI drop) and shows high redistribution---concept information is reshuffled into new SAE features rather than removed. TanGCE maintains near-zero redistribution across all $\lambda $ values. SAE metrics use $8\times $ TopK at $\delta {>}2\%$; L column pending re-run (marked ---).}}{11}{table.5}\protected@file@percent }
\newlabel{tab:lambda_sweep}{{5}{11}{$\lambda $ sweep comparing Ambient GCE and TanGCE at matched $\lambda $ values ($\lambda \in \{0.5, 4.0, 8.0\}$) at layer 8. L/NL: retrained linear/nonlinear probe accuracy. TanGCE retains the raw tangent projection norm as a confidence weight: if the gradient is mostly off-manifold, $\|\mathbf {P}_T(\nabla f)\| \ll 1$ and erasure is naturally attenuated. Ambient GCE at high $\lambda $ increases MI$_c$ (negative MI drop) and shows high redistribution---concept information is reshuffled into new SAE features rather than removed. TanGCE maintains near-zero redistribution across all $\lambda $ values. SAE metrics use $8\times $ TopK at $\delta {>}2\%$; L column pending re-run (marked ---)}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Effect of SAE dictionary size on concept removal detection. We train TopK SAEs ($k{=}64$) at $8\times $ and $64\times $ expansion on the same general-purpose WikiText corpus and re-evaluate all methods. Concept removal rate (\%) measures how many concept-correlated features are disrupted by erasure; damage rate (\%) measures collateral disruption to non-concept features. Correlation threshold $|r|{>}0.1$; disruption threshold $\delta {>}0.02$. The $8\times $ SAE (7{,}168 features) systematically underestimates concept removal due to polysemantic feature representations, particularly on gender where it reports 0\% removal for methods that demonstrably erase the concept.}}{11}{table.6}\protected@file@percent }
\newlabel{tab:sae_expansion}{{6}{11}{Effect of SAE dictionary size on concept removal detection. We train TopK SAEs ($k{=}64$) at $8\times $ and $64\times $ expansion on the same general-purpose WikiText corpus and re-evaluate all methods. Concept removal rate (\%) measures how many concept-correlated features are disrupted by erasure; damage rate (\%) measures collateral disruption to non-concept features. Correlation threshold $|r|{>}0.1$; disruption threshold $\delta {>}0.02$. The $8\times $ SAE (7{,}168 features) systematically underestimates concept removal due to polysemantic feature representations, particularly on gender where it reports 0\% removal for methods that demonstrably erase the concept}{table.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Cross-Modal Generalization: CelebA Visual Attributes}{11}{subsection.5.6}\protected@file@percent }
\newlabel{sec:celeba}{{5.6}{11}{Cross-Modal Generalization: CelebA Visual Attributes}{subsection.5.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces CLIP ViT-B/32 concept erasure on CelebA (validation HPO for $\lambda $). Each method's $\lambda ^*$ is selected from the same grid $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation nonlinear probe accuracy, ensuring a fair comparison. L/NL Leak: retrained linear / nonlinear probe accuracy on test (lower = better). $\Delta $Ctrl: mean control-task accuracy change across 5 least-correlated attributes (closer to zero = more surgical). Representation: CLIP ViT-B/32 \texttt  {pooler\_output} (768-dim).}}{12}{table.7}\protected@file@percent }
\newlabel{tab:celeba_clip_fair}{{7}{12}{CLIP ViT-B/32 concept erasure on CelebA (validation HPO for $\lambda $). Each method's $\lambda ^*$ is selected from the same grid $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation nonlinear probe accuracy, ensuring a fair comparison. L/NL Leak: retrained linear / nonlinear probe accuracy on test (lower = better). $\Delta $Ctrl: mean control-task accuracy change across 5 least-correlated attributes (closer to zero = more surgical). Representation: CLIP ViT-B/32 \texttt {pooler\_output} (768-dim)}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces CelebA all-40-attribute summary (CLIP ViT-B/32, validation HPO for $\lambda $). Each cell averages over all 40 binary CelebA attributes. $\lambda ^*$ is selected per method per concept from the grid $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation NL probe accuracy. NL Leak: mean nonlinear test accuracy across 40 concepts (lower = better). Mean $\Delta $Ctrl: mean control accuracy change (5 low-correlation controls per concept, averaged over 40 concepts). Worst $\Delta $Ctrl: worst single control drop averaged over 40 concepts.}}{12}{table.8}\protected@file@percent }
\newlabel{tab:celeba_clip_all40}{{8}{12}{CelebA all-40-attribute summary (CLIP ViT-B/32, validation HPO for $\lambda $). Each cell averages over all 40 binary CelebA attributes. $\lambda ^*$ is selected per method per concept from the grid $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation NL probe accuracy. NL Leak: mean nonlinear test accuracy across 40 concepts (lower = better). Mean $\Delta $Ctrl: mean control accuracy change (5 low-correlation controls per concept, averaged over 40 concepts). Worst $\Delta $Ctrl: worst single control drop averaged over 40 concepts}{table.8}{}}
