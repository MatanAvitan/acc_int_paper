\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Gender (Bias in Bios): per-model nonlinear-probe accuracy at the tightest and a moderate control-damage budget.} Two budgets are shown ($\Delta Y \le 1$pp and $\le 5$pp); each model group has three bars (gray = clean, blue = TanGCE\textsuperscript  {++}{}, red = Obliviator) plus a black tick at the per-model majority-class floor. Across all 13 models and both budgets, TanGCE\textsuperscript  {++}{} drives the probe to or below the floor; Obliviator stays close to the clean-rep accuracy on most settings. The full four-budget version of this figure is in App.~Fig.~\ref {fig:per_model_bars_gender_full}; sycophancy and safety analogues are in App.~Fig.~\ref {fig:per_model_bars_sycophancy_app}--\ref {fig:per_model_bars_safety_app}.}}{11}{figure.caption.18}\protected@file@percent }
\newlabel{fig:per_model_bars_gender}{{3}{11}{\textbf {Gender (Bias in Bios): per-model nonlinear-probe accuracy at the tightest and a moderate control-damage budget.} Two budgets are shown ($\Delta Y \le 1$pp and $\le 5$pp); each model group has three bars (gray = clean, blue = \TanGCEpp {}, red = Obliviator) plus a black tick at the per-model majority-class floor. Across all 13 models and both budgets, \TanGCEpp {} drives the probe to or below the floor; Obliviator stays close to the clean-rep accuracy on most settings. The full four-budget version of this figure is in App.~Fig.~\ref {fig:per_model_bars_gender_full}; sycophancy and safety analogues are in App.~Fig.~\ref {fig:per_model_bars_sycophancy_app}--\ref {fig:per_model_bars_safety_app}}{figure.caption.18}{}}
