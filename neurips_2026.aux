\@writefile{lot}{\contentsline {table}{\numberline {15}{\ignorespaces Local Table-2-style CelebA visual comparison using CLIP ViT-B/32 embeddings. For each target concept we intervene once per method and evaluate (i) concept leakage via retrained linear/nonlinear probes (lower is better) and (ii) mean control-task accuracy change across 3 least-correlated control attributes (closer to zero is better). Targets and controls: Male $\rightarrow $ Blurry,Narrow\_Eyes,Straight\_Hair; Smiling $\rightarrow $ Straight\_Hair,Bushy\_Eyebrows,Gray\_Hair; Blond\_Hair $\rightarrow $ Straight\_Hair,Narrow\_Eyes,Blurry. Lambdas follow the layer-8 single-model protocol (Appendix Table~\ref {tab:full_comparison}): all methods $\lambda {=}0.5$ except TanGCE{} $\lambda {=}8.0$.}}{42}{table.caption.37}\protected@file@percent }
\newlabel{tab:local_celeba_visual_table2}{{15}{42}{Local Table-2-style CelebA visual comparison using CLIP ViT-B/32 embeddings. For each target concept we intervene once per method and evaluate (i) concept leakage via retrained linear/nonlinear probes (lower is better) and (ii) mean control-task accuracy change across 3 least-correlated control attributes (closer to zero is better). Targets and controls: Male $\rightarrow $ Blurry,Narrow\_Eyes,Straight\_Hair; Smiling $\rightarrow $ Straight\_Hair,Bushy\_Eyebrows,Gray\_Hair; Blond\_Hair $\rightarrow $ Straight\_Hair,Narrow\_Eyes,Blurry. Lambdas follow the layer-8 single-model protocol (Appendix Table~\ref {tab:full_comparison}): all methods $\lambda {=}0.5$ except \TanGCE {} $\lambda {=}8.0$}{table.caption.37}{}}
\@writefile{lot}{\contentsline {table}{\numberline {16}{\ignorespaces Per-concept nonlinear probe leakage on CelebA (CLIP ViT-B/32), all 40 binary attributes. Each cell is retrained nonlinear probe test accuracy after erasure (lower = stronger erasure). $\lambda ^*$ is selected per method per concept from $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation NL accuracy. Bold marks the lowest leakage per row. Abbrev.: RandG = Random Global, RandS = Random Per-Sample, LinProj = Linear Projection, AmbGCE{} = ambient gradient-based concept erasure, TanGCE{} = tangent gradient-based concept erasure.}}{43}{table.caption.38}\protected@file@percent }
\newlabel{tab:celeba_clip_all40_per_concept_leak}{{16}{43}{Per-concept nonlinear probe leakage on CelebA (CLIP ViT-B/32), all 40 binary attributes. Each cell is retrained nonlinear probe test accuracy after erasure (lower = stronger erasure). $\lambda ^*$ is selected per method per concept from $\{0.5, 1.0, 2.0, 4.0, 8.0\}$ by lowest validation NL accuracy. Bold marks the lowest leakage per row. Abbrev.: RandG = Random Global, RandS = Random Per-Sample, LinProj = Linear Projection, \AmbGCE {} = ambient gradient-based concept erasure, \TanGCE {} = tangent gradient-based concept erasure}{table.caption.38}{}}
