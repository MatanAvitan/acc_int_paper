\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Geometry contrast between sycophancy and gender across completed layers 4, 8, and 12. This is a focused contrast between the primary nonlinear case and the diagnostic baseline, not an all-dataset geometry census. Lower intrinsic dimension and larger local-vs-global angle indicate stronger nonlinearity: a concept whose erasure direction varies significantly across the input space, making a single fixed direction insufficient to capture the full concept. Sycophancy shows substantially higher nonlinearity (dim 34--53, angle 76.9--82.6$^\circ $) compared to gender (dim 365--461, angle 51.8--55.8$^\circ $), supporting sycophancy as the primary case for manifold-aware erasure methods. This table demonstrates the geometric contrast but does not establish causality: it does not prove that the observed nonlinearity will be converted into lower displacement or higher utility preservation by any particular erasure method.}}{11}{table.caption.33}\protected@file@percent }
\newlabel{tab:geometry_contrast_summary}{{6}{11}{Geometry contrast between sycophancy and gender across completed layers 4, 8, and 12. This is a focused contrast between the primary nonlinear case and the diagnostic baseline, not an all-dataset geometry census. Lower intrinsic dimension and larger local-vs-global angle indicate stronger nonlinearity: a concept whose erasure direction varies significantly across the input space, making a single fixed direction insufficient to capture the full concept. Sycophancy shows substantially higher nonlinearity (dim 34--53, angle 76.9--82.6$^\circ $) compared to gender (dim 365--461, angle 51.8--55.8$^\circ $), supporting sycophancy as the primary case for manifold-aware erasure methods. This table demonstrates the geometric contrast but does not establish causality: it does not prove that the observed nonlinearity will be converted into lower displacement or higher utility preservation by any particular erasure method}{table.caption.33}{}}
\newlabel{fig:q1_transfer}{{1a}{11}{Q1: cross-domain subspace transfer (top-1 next-token agreement, $k \approx m_{\mathrm {tgt}}$). Each cell measures how well source-domain representations are preserved when projected onto the intrinsic subspace of the target domain. High diagonal values confirm subspace self-sufficiency. Sycophancy is the structural outlier: its row has near-zero off-diagonal transfer to biasbios (0.002) and code (0.13), indicating that sycophancy representations occupy a geometrically isolated region of the hidden space}{figure.caption.34}{}}
\newlabel{sub@fig:q1_transfer}{{a}{11}{Q1: cross-domain subspace transfer (top-1 next-token agreement, $k \approx m_{\mathrm {tgt}}$). Each cell measures how well source-domain representations are preserved when projected onto the intrinsic subspace of the target domain. High diagonal values confirm subspace self-sufficiency. Sycophancy is the structural outlier: its row has near-zero off-diagonal transfer to biasbios (0.002) and code (0.13), indicating that sycophancy representations occupy a geometrically isolated region of the hidden space}{figure.caption.34}{}}
\newlabel{fig:q2_sensitivity}{{1b}{11}{Q2: perturbation sensitivity (off/on top-1 agreement ratio, $\epsilon = 0.5$). Values above~1 (red) indicate that on-subspace perturbations are more disruptive than equally sized off-subspace perturbations, confirming that the subspace is the primary carrier of task-relevant computation. The sycophancy diagonal entry ($1.16$, darkest red) shows the strongest concentration among the five domains. Blue off-diagonal entries in the sycophancy column ($0.79$, $0.72$) indicate that the sycophancy subspace is a null direction for biasbios and code predictions}{figure.caption.34}{}}
\newlabel{sub@fig:q2_sensitivity}{{b}{11}{Q2: perturbation sensitivity (off/on top-1 agreement ratio, $\epsilon = 0.5$). Values above~1 (red) indicate that on-subspace perturbations are more disruptive than equally sized off-subspace perturbations, confirming that the subspace is the primary carrier of task-relevant computation. The sycophancy diagonal entry ($1.16$, darkest red) shows the strongest concentration among the five domains. Blue off-diagonal entries in the sycophancy column ($0.79$, $0.72$) indicate that the sycophancy subspace is a null direction for biasbios and code predictions}{figure.caption.34}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Geometric diagnostics at layer~8 of Qwen2.5-0.5B across five domains (biasbios, code, math, safety, sycophancy). Rows index the source domain whose representations are used; columns index the domain whose intrinsic subspace is applied. \textbf  {Left (Q1):} subspace transfer matrix. \textbf  {Right (Q2):} perturbation sensitivity ratio. Both experiments use 500 evaluation samples per domain; the Q1 intrinsic-dimension estimates use an additional 2{,}000 held-out reference samples not used in erasure training.}}{11}{figure.caption.34}\protected@file@percent }
\newlabel{fig:geom_combined}{{1}{11}{Geometric diagnostics at layer~8 of Qwen2.5-0.5B across five domains (biasbios, code, math, safety, sycophancy). Rows index the source domain whose representations are used; columns index the domain whose intrinsic subspace is applied. \textbf {Left (Q1):} subspace transfer matrix. \textbf {Right (Q2):} perturbation sensitivity ratio. Both experiments use 500 evaluation samples per domain; the Q1 intrinsic-dimension estimates use an additional 2{,}000 held-out reference samples not used in erasure training}{figure.caption.34}{}}
