\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces  \textbf  {Intuition for TanGCE{}.} \textbf  {(A)} An ambient nonlinear erasure step can reduce concept score by moving a representation away from the support of natural inputs. \textbf  {(B)} TanGCE{} estimates a local tangent space $T_{\mathbf  {x}_i}\mathcal  {M}$ from $k$ nearest-neighbor secants and projects the scorer gradient onto it. \textbf  {(C)} The projected update is scaled by the local singular spectrum, so motion is larger along well-supported tangent directions and smaller along thin, fragile ones, while remaining inside a local trust region. }}{3}{figure.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:tangce-intuition}{{1}{3}{\textbf {Intuition for \TanGCE {}.} \textbf {(A)} An ambient nonlinear erasure step can reduce concept score by moving a representation away from the support of natural inputs. \textbf {(B)} \TanGCE {} estimates a local tangent space $T_{\mathbf {x}_i}\mathcal {M}$ from $k$ nearest-neighbor secants and projects the scorer gradient onto it. \textbf {(C)} The projected update is scaled by the local singular spectrum, so motion is larger along well-supported tangent directions and smaller along thin, fragile ones, while remaining inside a local trust region}{figure.caption.3}{}}
