\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Sycophancy: Nonlinear Concept Erasure}{3}{subsection.4.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Geometry contrast between sycophancy and gender across completed layers 4, 8, and 12. Lower intrinsic dimension and larger local-vs-global angle indicate stronger nonlinearity: a concept whose erasure direction varies significantly across the input space, making a single fixed direction insufficient to capture the full concept. Sycophancy shows substantially higher nonlinearity (dim 34--53, angle 76.9--82.6$^\circ $) compared to gender (dim 365--461, angle 51.8--55.8$^\circ $), supporting sycophancy as the primary case for manifold-aware erasure methods. This table demonstrates the geometric contrast but does not establish causality: it does not prove that the observed nonlinearity will be converted into lower displacement or higher utility preservation by any particular erasure method.}}{4}{table.3}\protected@file@percent }
\newlabel{tab:geometry_contrast_summary}{{3}{4}{Geometry contrast between sycophancy and gender across completed layers 4, 8, and 12. Lower intrinsic dimension and larger local-vs-global angle indicate stronger nonlinearity: a concept whose erasure direction varies significantly across the input space, making a single fixed direction insufficient to capture the full concept. Sycophancy shows substantially higher nonlinearity (dim 34--53, angle 76.9--82.6$^\circ $) compared to gender (dim 365--461, angle 51.8--55.8$^\circ $), supporting sycophancy as the primary case for manifold-aware erasure methods. This table demonstrates the geometric contrast but does not establish causality: it does not prove that the observed nonlinearity will be converted into lower displacement or higher utility preservation by any particular erasure method}{table.3}{}}
