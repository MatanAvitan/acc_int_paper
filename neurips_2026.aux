\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Main result.} Best-in-budget distance to majority-class chance (signed $S - S_{\text  {floor}}$ at the trajectory step closest to floor in pp; $0$ = at chance, lower in absolute value is better) and panels at floor ($|S{-}S_{\text  {floor}}| \le 0.5$pp) over reachable panels, on all 39 NLP panels (13 model families $\times $ 3 concepts) at 50\%-depth using a fresh nonlinear probe ($h{=}128$, 200 SGD, patience 3). $\lambda $-based methods use $\lambda = 29.31$, the mean per-row $\lambda _i$ produced by the proposed pipeline (Appendix Table~\ref {tab:lambda_stats}); LEACE-only and LEACE$+$CovMatch $K{=}2$ are one-shot closed-form. Obliviator uses paper-HP. TanGCE{} is the proposed pipeline at fixed $\varepsilon {=}0.1$, $h{=}512$. Best per column in \textbf  {bold}.}}{14}{table.caption.45}\protected@file@percent }
\newlabel{tab:main_results_unified}{{2}{14}{\textbf {Main result.} Best-in-budget distance to majority-class chance (signed $S - S_{\text {floor}}$ at the trajectory step closest to floor in pp; $0$ = at chance, lower in absolute value is better) and panels at floor ($|S{-}S_{\text {floor}}| \le 0.5$pp) over reachable panels, on all 39 NLP panels (13 model families $\times $ 3 concepts) at 50\%-depth using a fresh nonlinear probe ($h{=}128$, 200 SGD, patience 3). $\lambda $-based methods use $\lambda = 29.31$, the mean per-row $\lambda _i$ produced by the proposed pipeline (Appendix Table~\ref {tab:lambda_stats}); LEACE-only and LEACE$+$CovMatch $K{=}2$ are one-shot closed-form. Obliviator uses paper-HP. \TanGCE {} is the proposed pipeline at fixed $\varepsilon {=}0.1$, $h{=}512$. Best per column in \textbf {bold}}{table.caption.45}{}}
