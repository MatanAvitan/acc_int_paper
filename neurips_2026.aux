\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Main result.} \emph  {Leakage (pp)}: signed $S - S_{\text  {floor}}$ at the trajectory step closest to majority-class chance, in pp; $0$ = at chance, lower in absolute value = stronger erasure. \emph  {@chance}: settings driven to chance ($|S{-}S_{\text  {floor}}| \le 0.5$pp) over settings the method reached the budget on. All 39 NLP panels (13 model families $\times $ 3 concepts) at 50\%-depth, fresh nonlinear probe ($h{=}128$, 200 SGD, patience 3); LEACE-only and LEACE$+$CovMatch $K{=}2$ are one-shot closed-form. TanGCE\textsuperscript  {++}{} is the proposed pipeline at fixed $\varepsilon {=}0.1$, $h{=}512$; TanGCE{} drops both preprocessing stages and TanGCE\textsuperscript  {+}{} drops only CovMatch. Bold = column-best; multiple methods within 0.05pp of the best are all bolded. Per-panel detail across all 39 panels is in App.~Tab.~\ref {tab:per_panel_breakdown}.}}{9}{table.caption.16}\protected@file@percent }
\newlabel{tab:main_results_unified}{{1}{9}{\textbf {Main result.} \emph {Leakage (pp)}: signed $S - S_{\text {floor}}$ at the trajectory step closest to majority-class chance, in pp; $0$ = at chance, lower in absolute value = stronger erasure. \emph {@chance}: settings driven to chance ($|S{-}S_{\text {floor}}| \le 0.5$pp) over settings the method reached the budget on. All 39 NLP panels (13 model families $\times $ 3 concepts) at 50\%-depth, fresh nonlinear probe ($h{=}128$, 200 SGD, patience 3); LEACE-only and LEACE$+$CovMatch $K{=}2$ are one-shot closed-form. \TanGCEpp {} is the proposed pipeline at fixed $\varepsilon {=}0.1$, $h{=}512$; \TanGCE {} drops both preprocessing stages and \TanGCEp {} drops only CovMatch. Bold = column-best; multiple methods within 0.05pp of the best are all bolded. Per-panel detail across all 39 panels is in App.~Tab.~\ref {tab:per_panel_breakdown}}{table.caption.16}{}}
\@writefile{toc}{\contentsline {paragraph}{How to read the @chance counts.}{9}{section*.15}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Per-model bars and the surgicality signal}{9}{subsection.6.2}\protected@file@percent }
\newlabel{sec:pareto_obliviator}{{6.2}{9}{Per-model bars and the surgicality signal}{subsection.6.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Aggregated NLP leakage vs.\ control-damage budget.} Mean $|S - S_{\text  {floor}}|$ in pp across the 39 NLP settings (13 model families $\times $ 3 concepts at 50\%-depth) for each method, plotted against the four control-damage budgets $\Delta Y \in \{1, 3, 5, 10\}$pp. The black ``X'' at $x=0$ is the shared starting point: mean nonlinear-probe leakage on the raw, un-erased representations ($\sim $24pp); every line begins from this anchor. Lower is better; the $y$-axis floor is the per-setting majority-class chance. The TanGCE{} family (TanGCE\textsuperscript  {++}{}, TanGCE\textsuperscript  {+}{}, TanGCE{}) traces the lowest envelope at every budget --- TanGCE\textsuperscript  {++}{} below $1$pp from $\le 3$pp onward --- while baselines (Obliviator, LEACE\,+\,CovMatch K=2, IGBP, AmbGCE, INLP, LEACE) plateau at $4$--$18$pp regardless of how much utility one is willing to sacrifice. The visual gap between the TanGCE{} curves and the rest reproduces the column-best ranking in Tab.~\ref {tab:main_results_unified}.}}{10}{figure.caption.17}\protected@file@percent }
\newlabel{fig:aggregated_nlp_results}{{2}{10}{\textbf {Aggregated NLP leakage vs.\ control-damage budget.} Mean $|S - S_{\text {floor}}|$ in pp across the 39 NLP settings (13 model families $\times $ 3 concepts at 50\%-depth) for each method, plotted against the four control-damage budgets $\Delta Y \in \{1, 3, 5, 10\}$pp. The black ``X'' at $x=0$ is the shared starting point: mean nonlinear-probe leakage on the raw, un-erased representations ($\sim $24pp); every line begins from this anchor. Lower is better; the $y$-axis floor is the per-setting majority-class chance. The \TanGCE {} family (\TanGCEpp {}, \TanGCEp {}, \TanGCE {}) traces the lowest envelope at every budget --- \TanGCEpp {} below $1$pp from $\le 3$pp onward --- while baselines (Obliviator, LEACE\,+\,CovMatch K=2, IGBP, AmbGCE, INLP, LEACE) plateau at $4$--$18$pp regardless of how much utility one is willing to sacrifice. The visual gap between the \TanGCE {} curves and the rest reproduces the column-best ranking in Tab.~\ref {tab:main_results_unified}}{figure.caption.17}{}}
