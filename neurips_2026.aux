\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Full erasure method comparison at layer 8 across three concept domains. All methods use $\lambda {=}0.5$ except TanGCE (raw) which uses $\lambda {=}8.0$ to compensate for attenuated projection norms (Section~\ref {sec:lambda_sweep}). NL Leak: retrained nonlinear MLP probe accuracy (lower = better concept removal). $\Delta $Ctrl: downstream control task accuracy change relative to clean representations (closer to zero = more surgical). Redist\%: fraction of non-concept SAE features that become concept-correlated post-erasure (lower = less information reshuffling). Model: Qwen2.5-0.5B. SAE: 8$\times $ TopK, $k{=}64$. Control tasks: answer matching (sycophancy), profession classification (gender), helpfulness (safety).}}{5}{table.2}\protected@file@percent }
\newlabel{tab:full_comparison}{{2}{5}{Full erasure method comparison at layer 8 across three concept domains. All methods use $\lambda {=}0.5$ except TanGCE (raw) which uses $\lambda {=}8.0$ to compensate for attenuated projection norms (Section~\ref {sec:lambda_sweep}). NL Leak: retrained nonlinear MLP probe accuracy (lower = better concept removal). $\Delta $Ctrl: downstream control task accuracy change relative to clean representations (closer to zero = more surgical). Redist\%: fraction of non-concept SAE features that become concept-correlated post-erasure (lower = less information reshuffling). Model: Qwen2.5-0.5B. SAE: 8$\times $ TopK, $k{=}64$. Control tasks: answer matching (sycophancy), profession classification (gender), helpfulness (safety)}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Mutual information and fidelity metrics (layer 8). MI$_c$: concept mutual information in original representation space via $k$-NN estimator (lower = better erasure). MI$_\text  {ctrl}$: control-label mutual information (higher = better preservation of task-relevant information). Clean baselines: sycophancy MI$_c{=}0.189$, MI$_\text  {ctrl}{=}1.157$; gender MI$_c{=}0.074$, MI$_\text  {ctrl}{=}0.903$; safety MI$_c{=}0.160$, MI$_\text  {ctrl}{=}0.077$. $L_2$: mean $\ell _2$ displacement from clean representations.}}{5}{table.3}\protected@file@percent }
\newlabel{tab:full_comparison_detail}{{3}{5}{Mutual information and fidelity metrics (layer 8). MI$_c$: concept mutual information in original representation space via $k$-NN estimator (lower = better erasure). MI$_\text {ctrl}$: control-label mutual information (higher = better preservation of task-relevant information). Clean baselines: sycophancy MI$_c{=}0.189$, MI$_\text {ctrl}{=}1.157$; gender MI$_c{=}0.074$, MI$_\text {ctrl}{=}0.903$; safety MI$_c{=}0.160$, MI$_\text {ctrl}{=}0.077$. $L_2$: mean $\ell _2$ displacement from clean representations}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}TanGCE Achieves Lowest Leakage Across All Domains}{5}{subsection.4.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Control Task Preservation}{5}{subsection.4.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Effect of disruption threshold $\delta $ on concept removal and damage rates ($64\times $ SAE). At the lenient $\delta {>}2\%$ threshold, many features register as ``damaged'' from minor perturbation; at $\delta {>}20\%$, only features with substantial activation change count. TanGCE's damage drops to 1--11\% at $\delta {>}20\%$, while ConceptSAE Soft retains 17--80\% damage, confirming its lack of surgical precision.}}{6}{table.4}\protected@file@percent }
\newlabel{tab:damage_threshold}{{4}{6}{Effect of disruption threshold $\delta $ on concept removal and damage rates ($64\times $ SAE). At the lenient $\delta {>}2\%$ threshold, many features register as ``damaged'' from minor perturbation; at $\delta {>}20\%$, only features with substantial activation change count. TanGCE's damage drops to 1--11\% at $\delta {>}20\%$, while ConceptSAE Soft retains 17--80\% damage, confirming its lack of surgical precision}{table.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Near-Zero Redistribution}{6}{subsection.4.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Damage threshold sensitivity.}{6}{table.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}The $\lambda $ Sweep: Off-Manifold Displacement Creates Spurious Correlations}{6}{subsection.4.4}\protected@file@percent }
\newlabel{sec:lambda_sweep}{{4.4}{6}{The $\lambda $ Sweep: Off-Manifold Displacement Creates Spurious Correlations}{subsection.4.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces $\lambda $ sweep comparing Ambient GCE, TanGCE (renorm), and TanGCE (raw) at layer 8. TanGCE (raw) retains the raw tangent projection norm as a confidence weight: if the gradient is mostly off-manifold, $\|\mathbf  {P}_T(\nabla f)\| \ll 1$ and erasure is naturally attenuated. Ambient GCE at high $\lambda $ increases MI$_c$ (negative MI drop) and shows high redistribution---concept information is reshuffled into new SAE features rather than removed. TanGCE (raw) maintains near-zero redistribution across all $\lambda $ values.}}{7}{table.5}\protected@file@percent }
\newlabel{tab:lambda_sweep}{{5}{7}{$\lambda $ sweep comparing Ambient GCE, TanGCE (renorm), and TanGCE (raw) at layer 8. TanGCE (raw) retains the raw tangent projection norm as a confidence weight: if the gradient is mostly off-manifold, $\|\mathbf {P}_T(\nabla f)\| \ll 1$ and erasure is naturally attenuated. Ambient GCE at high $\lambda $ increases MI$_c$ (negative MI drop) and shows high redistribution---concept information is reshuffled into new SAE features rather than removed. TanGCE (raw) maintains near-zero redistribution across all $\lambda $ values}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Effect of SAE dictionary size on concept removal detection. We train TopK SAEs ($k{=}64$) at $8\times $ and $64\times $ expansion on the same general-purpose WikiText corpus and re-evaluate all methods. Concept removal rate (\%) measures how many concept-correlated features are disrupted by erasure; damage rate (\%) measures collateral disruption to non-concept features. Correlation threshold $|r|{>}0.1$; disruption threshold $\delta {>}0.02$. The $8\times $ SAE (7{,}168 features) systematically underestimates concept removal due to polysemantic feature representations, particularly on gender where it reports 0\% removal for methods that demonstrably erase the concept.}}{7}{table.6}\protected@file@percent }
\newlabel{tab:sae_expansion}{{6}{7}{Effect of SAE dictionary size on concept removal detection. We train TopK SAEs ($k{=}64$) at $8\times $ and $64\times $ expansion on the same general-purpose WikiText corpus and re-evaluate all methods. Concept removal rate (\%) measures how many concept-correlated features are disrupted by erasure; damage rate (\%) measures collateral disruption to non-concept features. Correlation threshold $|r|{>}0.1$; disruption threshold $\delta {>}0.02$. The $8\times $ SAE (7{,}168 features) systematically underestimates concept removal due to polysemantic feature representations, particularly on gender where it reports 0\% removal for methods that demonstrably erase the concept}{table.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Polysemanticity Confounds Linear Correlation Metrics}{7}{subsection.4.5}\protected@file@percent }
\newlabel{sec:polysemanticity}{{4.5}{7}{Polysemanticity Confounds Linear Correlation Metrics}{subsection.4.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Geometry contrast between sycophancy and gender across completed layers 4, 8, and 12. Lower intrinsic dimension and larger local-vs-global angle indicate stronger nonlinearity: a concept whose erasure direction varies significantly across the input space, making a single fixed direction insufficient to capture the full concept. Sycophancy shows substantially higher nonlinearity (dim 34--53, angle 76.9--82.6$^\circ $) compared to gender (dim 365--461, angle 51.8--55.8$^\circ $), supporting sycophancy as the primary case for manifold-aware erasure methods. This table demonstrates the geometric contrast but does not establish causality: it does not prove that the observed nonlinearity will be converted into lower displacement or higher utility preservation by any particular erasure method.}}{8}{table.7}\protected@file@percent }
\newlabel{tab:geometry_contrast_summary}{{7}{8}{Geometry contrast between sycophancy and gender across completed layers 4, 8, and 12. Lower intrinsic dimension and larger local-vs-global angle indicate stronger nonlinearity: a concept whose erasure direction varies significantly across the input space, making a single fixed direction insufficient to capture the full concept. Sycophancy shows substantially higher nonlinearity (dim 34--53, angle 76.9--82.6$^\circ $) compared to gender (dim 365--461, angle 51.8--55.8$^\circ $), supporting sycophancy as the primary case for manifold-aware erasure methods. This table demonstrates the geometric contrast but does not establish causality: it does not prove that the observed nonlinearity will be converted into lower displacement or higher utility preservation by any particular erasure method}{table.7}{}}
